{
  "name": "ui-diff-engine",
  "version": "1.0.0",
  "description": "Figma ↔ Browser UI diff engine with relative positioning, padding comparison and severity-graded reports",
  "main": "compare-engine.js",
  "scripts": {
    "extract:figma":   "node figma-extractor.js",
    "extract:browser": "node browser-extractor.js",
    "compare":         "node compare-engine.js",
    "pipeline":        "node run-pipeline.js",
    "example": "node run-pipeline.js --figma ./example/figma-export.json --url https://dss-r3.bmbdss.sit.dss.ife.ninja/sa... --out ./reports --mobile true"
